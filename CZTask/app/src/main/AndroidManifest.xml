<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-feature android:name="android.hardware.type.watch" />
    <!-- allowBackup=false: a restored backup carrying stale clock-guard state onto
         a device with a wrong clock is exactly the confusion we defend against;
         the dataset is small enough to re-enter. Escape hatch: JsonDump. -->
    <application
        android:name=".CzTaskApp"
        android:allowBackup="false"
        android:label="CZ Task">
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />
    </application>
</manifest>
